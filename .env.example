# Development Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Django Configuration
DJANGO_DEBUG=True              # Set to True for development, False for production
DJANGO_SECRET_KEY=your-secret-key-here  # Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# Deployment Configuration (optional, defaults provided)
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# API Keys
HUDDY_OPENROUTER_API_KEY_1=your-openrouter-api-key
OP_HUDDY_AI_PORTFOLIO_API_KEY=your-alternative-api-key
Gemini_API_KEY_1=your-gemini-api-key

# Logging Configuration (optional)
LOG_LEVEL=DEBUG              # DEBUG, INFO, WARNING, ERROR, CRITICAL
